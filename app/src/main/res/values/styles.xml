<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 功能按钮样式 -->
    <style name="FunctionButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">16dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:elevation">2dp</item>
        <item name="android:shadowColor">@color/black</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>
    
    <!-- 按钮文字样式 -->
    <style name="FunctionButtonText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>
    
    <!-- 按钮图标样式 -->
    <style name="FunctionButtonIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_marginEnd">12dp</item>
    </style>
    
    <!-- 按钮箭头样式 -->
    <style name="FunctionButtonArrow">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
    </style>

    <style name="BottomNavigationTextActive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="BottomNavigationTextInactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="AppActionBar" parent="Widget.MaterialComponents.ActionBar.Primary">
        <item name="android:background">@color/background_card</item>
        <item name="background">@color/background_card</item>
        <item name="android:titleTextStyle">@style/AppActionBarTitle</item>
        <item name="titleTextStyle">@style/AppActionBarTitle</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="AppActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- 根页面 Toolbar：无阴影、无边框 -->
    <style name="MainToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@android:color/transparent</item>
        <item name="background">@android:color/transparent</item>
        <item name="android:elevation">0dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:outlineProvider">none</item>
    </style>
</resources>
