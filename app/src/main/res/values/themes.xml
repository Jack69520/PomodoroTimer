<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PomodoroTimer" parent="Theme.MaterialComponents.DayNight">
        <!-- Primary brand color. 允许动态颜色覆盖主题默认值-->
        <item name="colorPrimary">@color/skyblue</item>
        <item name="colorPrimaryVariant">@color/default_theme_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. 禁用主题默认的状态栏颜色，由代码动态控制-->
        <item name="android:statusBarColor">@color/background_card</item>
        <item name="actionBarStyle">@style/AppActionBar</item>
        <item name="android:actionBarStyle">@style/AppActionBar</item>
        <!-- Customize your theme here. -->
        <item name="android:navigationBarColor" tools:targetApi="l">@color/background_card</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.PomodoroTimer.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/skyblue</item>
        <item name="colorPrimaryVariant">@color/default_theme_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:statusBarColor">@color/background_card</item>
        <item name="android:navigationBarColor">@color/background_card</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- 深色主题 -->
    <style name="Theme.PomodoroTimer.Dark" parent="Theme.PomodoroTimer">
        <item name="colorPrimary">@color/default_theme_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/dark_background</item>
    </style>

    <!-- 夜间模式主题选择器 -->
    <style name="Theme.PomodoroTimer.DayNight" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">?attr/colorPrimary</item>
        <item name="colorPrimaryDark">?attr/colorPrimaryDark</item>
        <item name="android:forceDarkAllowed">true</item>
    </style>
</resources>