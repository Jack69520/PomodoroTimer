<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="10dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/subtask_order"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:text="@string/layout_placeholder_pomodoro_count"
        android:textSize="12sp"
        android:textColor="@color/text_primary"
        android:background="@drawable/order_background"
        android:gravity="center"
        android:layout_marginEnd="8dp" />

    <CheckBox
        android:id="@+id/subtask_checkbox"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginEnd="8dp" />

    <TextView
        android:id="@+id/subtask_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="16sp"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/subtask_pomodoro_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/task_pomodoro_emoji"
        android:textSize="14sp"
        android:layout_marginEnd="4dp" />

    <EditText
        android:id="@+id/subtask_estimated_pomodoros"
        android:layout_width="48dp"
        android:layout_height="36dp"
        android:inputType="number"
        android:textSize="14sp"
        android:gravity="center"
        android:background="@drawable/edit_text_background"
        android:layout_marginEnd="8dp" />

    <TextView
        android:id="@+id/subtask_pomodoro_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginEnd="8dp" />

</LinearLayout>
