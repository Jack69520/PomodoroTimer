<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        android:padding="12dp">

        <!-- 账户信息卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/account_section_background"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <!-- 头像区域 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/account_avatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_default_avatar"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/account_tap_change_avatar"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

            <!-- 账户ID -->
            <TextView
                android:id="@+id/account_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/layout_placeholder_account_id"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/rounded_background_light"
                android:padding="8dp"
                android:layout_marginBottom="40dp"/>

            <!-- 账户昵称 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background_light"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/account_label_nickname"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/account_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:text="@string/account_placeholder_nickname"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_edit"
                    android:layout_marginStart="8dp"
                    android:alpha="0.6"/>

            </LinearLayout>

            <!-- 个性化签名 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background_light"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/account_label_signature"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/account_signature"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="4"
                    android:text="@string/account_placeholder_signature"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="end"
                    android:maxLines="2"
                    android:ellipsize="end"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_edit"
                    android:layout_marginStart="8dp"
                    android:alpha="0.6"/>

            </LinearLayout>

        </LinearLayout>

        <!-- 按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 登录状态下的按钮 -->
            <Button
                android:id="@+id/btn_change_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/account_btn_change_password_label"
                android:textSize="16sp"
                android:background="@drawable/button_blue_background"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/account_btn_logout"
                android:textSize="16sp"
                android:background="@drawable/button_gray_background"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_delete_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/account_btn_delete_account"
                android:textSize="16sp"
                android:background="@drawable/button_red_background"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- 未登录状态下的按钮 -->
            <Button
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/account_btn_register_short"
                android:textSize="16sp"
                android:background="@drawable/button_blue_background"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/account_btn_login"
                android:textSize="16sp"
                android:background="@drawable/button_green_background"
                android:textColor="@color/white"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
