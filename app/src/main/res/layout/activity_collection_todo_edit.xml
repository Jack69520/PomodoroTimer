<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="40dp">

        <TextView
            android:id="@+id/task_type_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task_type_collection"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:background="@color/pink_01"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/task_label_collection_title"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edit_title"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="@string/task_hint_collection_title"
            android:textSize="16sp"
            android:background="@drawable/edit_text_background"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/task_label_collection_description"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edit_description"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/task_hint_collection_description"
            android:textSize="16sp"
            android:background="@drawable/edit_text_background"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/task_label_category"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/edit_category"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_background" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/task_label_priority"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/edit_priority"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_background" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/task_label_tags"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edit_tags"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/task_hint_tags"
            android:textSize="16sp"
            android:background="@drawable/edit_text_background"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/task_label_due_date"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/edit_due_date"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="@string/task_hint_due_date"
                android:textSize="16sp"
                android:background="@drawable/edit_text_background"
                android:paddingHorizontal="16dp"
                android:focusable="false"
                android:clickable="true"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_clear_due_date"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/common_btn_clear"
                android:textSize="14sp"
                android:background="@drawable/button_red_background"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/task_subtasks_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/task_collection_subtask_hint"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/subtask_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/subtask_input"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginBottom="50dp"
                android:hint="@string/task_subtask_hint"
                android:textSize="16sp"
                android:background="@drawable/edit_text_background"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/subtask_pomodoro_input"
                android:layout_width="56dp"
                android:layout_height="48dp"
                android:layout_marginBottom="50dp"
                android:hint="@string/layout_placeholder_pomodoro_count"
                android:inputType="number"
                android:textSize="16sp"
                android:gravity="center"
                android:background="@drawable/edit_text_background"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_add_subtask"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginBottom="50dp"
                android:text="@string/task_add_subtask"
                android:background="@drawable/button_green_background"
                android:textColor="@color/text_primary"
                android:paddingHorizontal="16dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
