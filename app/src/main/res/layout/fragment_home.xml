<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- 计时器部分 -->
    <TextView
        android:id="@+id/timer_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/layout_placeholder_timer"
        android:textSize="72sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:shadowColor="@color/black"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/study_duration_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/home_study_duration_hint"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="16dp"/>

    <!-- 主要控制按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/control_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:textSize="20sp"
            android:text="@string/start_button"
            android:background="@drawable/button_green_background"
            android:textColor="@color/text_primary"
            android:elevation="4dp"/>

        <Button
            android:id="@+id/reset_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/reset_button"
            android:textSize="20sp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/button_orange_background"
            android:textColor="@color/text_primary"
            android:elevation="4dp"/>
    </LinearLayout>

    <!-- 筛选器区域 - 可折叠 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/account_section_background"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <!-- 筛选器标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:id="@+id/filter_header">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_filter_title"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/filter_arrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_right"
                android:rotation="90"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_clear_filter"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:text="@string/home_filter_clear"
                android:textSize="12sp"
                android:background="@drawable/button_red_background"
                android:textColor="@color/white"
                android:paddingHorizontal="12dp"/>

        </LinearLayout>

        <!-- 筛选器内容区域 - 默认隐藏 -->
        <LinearLayout
            android:id="@+id/filter_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Spinner
                    android:id="@+id/priority_filter_spinner"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/spinner_background"/>

                <Spinner
                    android:id="@+id/due_date_filter_spinner"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/spinner_background"/>

                <Spinner
                    android:id="@+id/category_filter_spinner"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/spinner_background"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/todo_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_marginTop="5dp"/>
</LinearLayout>